APP_NAME=Trending News Service
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/trending_news
REDIS_URL=redis://localhost:6379/0

CACHE_TTL_SECONDS=180
TRENDING_LOOKBACK_HOURS=24
TRENDING_DECAY_HOURS=12
TRENDING_NEIGHBOR_WEIGHT=0.8
BUCKET_CELL_KM=10.0
DEFAULT_RADIUS_KM=25.0
MAX_TRENDING_LIMIT=20
TRENDING_SCORE_WINDOW=24h
CREATE_TABLES_ON_STARTUP=false
